              "path": ["api", "users", "{{user_id}}", "role"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User role updated successfully', function() {",
                  "  pm.response.to.have.status(200);",
